#!/bin/bash
# Post-commit: bump Last Updated: in .claude/architecture.md and
# .claude/ignorefiles.md. Cross-platform sed -i (BSD vs GNU).
# Reports new/deleted files and DEPRECATED markers as info — does
# not auto-edit anything else.

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
ARCH_FILE=".claude/architecture.md"
IGNORE_FILE=".claude/ignorefiles.md"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

cd "$PROJECT_ROOT"

# Skip cleanly if .claude/ isn't there yet (e.g., first-day repo).
if [ ! -f "$ARCH_FILE" ] && [ ! -f "$IGNORE_FILE" ]; then
    exit 0
fi

echo -e "${BLUE}→ post-commit${NC}"

sed_inplace() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "$@"
    else
        sed -i "$@"
    fi
}

# --- Info: new files in this commit ---
NEW_FILES="$(git diff-tree --no-commit-id --name-only -r HEAD --diff-filter=A 2>/dev/null || true)"
if [ -n "$NEW_FILES" ]; then
    NEW_COUNT="$(echo "$NEW_FILES" | wc -l | tr -d ' ')"
    echo -e "${GREEN}  + $NEW_COUNT new file(s) in this commit${NC}"
fi

# --- Info: deleted files in this commit ---
DELETED="$(git diff-tree --no-commit-id --diff-filter=D --name-only -r HEAD 2>/dev/null || true)"
if [ -n "$DELETED" ]; then
    DEL_COUNT="$(echo "$DELETED" | wc -l | tr -d ' ')"
    echo -e "${YELLOW}  - $DEL_COUNT deleted file(s) in this commit${NC}"
fi

# --- Info: DEPRECATED markers added in this commit ---
DEPRECATED="$(git diff HEAD~1 HEAD 2>/dev/null \
    | grep -E "^\+.*# DEPRECATED|^\+.*# DEAD|^\+.*# TODO.*remove" \
    | head -5 || true)"
if [ -n "$DEPRECATED" ]; then
    echo -e "${BLUE}  ⓘ DEPRECATED/DEAD markers detected — consider an entry in $IGNORE_FILE${NC}"
fi

# --- Bump timestamp ---
TIMESTAMP="$(date '+%Y-%m-%d %H:%M:%S')"
[ -f "$ARCH_FILE" ] && sed_inplace "s/\*\*Last Updated:\*\* .*/\*\*Last Updated:\*\* $TIMESTAMP/" "$ARCH_FILE" 2>/dev/null || true
[ -f "$IGNORE_FILE" ] && sed_inplace "s/\*\*Last Updated:\*\* .*/\*\*Last Updated:\*\* $TIMESTAMP/" "$IGNORE_FILE" 2>/dev/null || true

echo -e "${GREEN}✓ timestamps bumped to $TIMESTAMP${NC}"
exit 0
