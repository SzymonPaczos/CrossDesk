#!/bin/bash
# Pre-push: stack-agnostic security review using grep.
# Hard-fails on hardcoded secrets in changed files. Soft-warns on
# console.log / print() / TODO+FIXME in newly added lines.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "🔍 pre-push: security review"
echo "─────────────────────────────────────────────"

DEFAULT_BRANCH="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's@^refs/remotes/origin/@@' || echo main)"

CHANGED_FILES="$(git diff --name-only "origin/$DEFAULT_BRANCH"...HEAD 2>/dev/null \
    || git diff --name-only HEAD)"

if [ -z "$CHANGED_FILES" ]; then
    echo "ℹ  No changes vs origin/$DEFAULT_BRANCH — skipping."
    exit 0
fi

# Skip helper: returns 0 if path is a test/fixture/known-allowed file.
is_excluded() {
    case "$1" in
        node_modules/*|*.env|*/test/*|*/tests/*|test_*|*_test.*|*.spec.*|*spec.ts|*spec.tsx|*spec.js|*mock*|*fixture*|*conftest*|infra/certs/generate_mtls.sh|.githooks/*|guest/crates/proto/*|host/src/crossdesk_host/proto/*) return 0 ;;
    esac
    return 1
}

# === 1. Hardcoded secrets (HARD FAIL) =====================================
echo "🔐 hardcoded secrets ..."
SECRET_PATTERNS='(password|api[_-]?key|secret|token)[[:space:]]*=[[:space:]]*["'"'"'][A-Za-z0-9._\-]{8,}["'"'"']'
SECRET_HITS=""
for f in $CHANGED_FILES; do
    [ -f "$f" ] || continue
    is_excluded "$f" && continue
    if grep -E -l "$SECRET_PATTERNS" "$f" >/dev/null 2>&1; then
        SECRET_HITS="$SECRET_HITS $f"
    fi
done
if [ -n "$SECRET_HITS" ]; then
    echo "❌ potential hardcoded secrets in:"
    for f in $SECRET_HITS; do
        echo "    $f"
    done
    echo "   Move them to env vars or a gitignored .env, then retry."
    exit 1
fi

# === 2. console.log in TS/JS hot paths (WARN) =============================
echo "🖨  console.log in TS/JS ..."
COUNT=0
for f in $CHANGED_FILES; do
    [ -f "$f" ] || continue
    is_excluded "$f" && continue
    case "$f" in
        *.ts|*.tsx|*.js|*.jsx) ;;
        *) continue ;;
    esac
    while IFS= read -r line; do
        echo "    $f:$line"
        COUNT=$((COUNT + 1))
        [ $COUNT -ge 5 ] && break 2
    done < <(grep -n -E 'console\.(log|debug|warn)' "$f" 2>/dev/null || true)
done

# === 3. print() in Python hot paths (WARN) ================================
echo "🐍 print() in Python ..."
COUNT=0
for f in $CHANGED_FILES; do
    [ -f "$f" ] || continue
    is_excluded "$f" && continue
    case "$f" in
        *.py) ;;
        *) continue ;;
    esac
    case "$f" in
        build_proto.py|scripts/*|tools/*) continue ;;
    esac
    while IFS= read -r line; do
        echo "    $f:$line"
        COUNT=$((COUNT + 1))
        [ $COUNT -ge 5 ] && break 2
    done < <(grep -n -E '^\s*print\(' "$f" 2>/dev/null || true)
done

# === 4. TODO/FIXME added in this push (INFO) ==============================
echo "📝 TODO/FIXME added vs origin/$DEFAULT_BRANCH ..."
git diff "origin/$DEFAULT_BRANCH"...HEAD 2>/dev/null \
    | grep -E '^\+.*(TODO|FIXME)' \
    | head -10 || true

# === 5. Supply-chain audit (HARD FAIL when tools available) ==============
# These run automatically when the corresponding scanner is installed.
# Skipped silently if not — keeps the hook usable on minimal dev machines.
# To install everything: see docs/AUDIT_REPORT.md "How to re-run".

if command -v cargo-audit >/dev/null 2>&1; then
    echo "🦀 cargo audit (guest) ..."
    (cd "$REPO_ROOT/guest" && cargo audit --quiet --deny warnings 2>&1) || {
        echo "❌ cargo audit found vulnerabilities in guest workspace."
        exit 1
    }
    echo "🦀 cargo audit (gui) ..."
    (cd "$REPO_ROOT/gui" && cargo audit --quiet --deny warnings 2>&1) || {
        echo "❌ cargo audit found vulnerabilities in gui workspace."
        exit 1
    }
fi

if command -v cargo-deny >/dev/null 2>&1; then
    echo "🚧 cargo deny check (guest) ..."
    (cd "$REPO_ROOT/guest" && cargo deny check --hide-inclusion-graph >/dev/null 2>&1) || {
        echo "❌ cargo deny rejected guest workspace — re-run for details."
        exit 1
    }
    echo "🚧 cargo deny check (gui) ..."
    (cd "$REPO_ROOT/gui" && cargo deny check --hide-inclusion-graph >/dev/null 2>&1) || {
        echo "❌ cargo deny rejected gui workspace — re-run for details."
        exit 1
    }
fi

if command -v gitleaks >/dev/null 2>&1; then
    echo "🔑 gitleaks (git history) ..."
    # Scan git history rather than worktree — leaves out cached
    # build artifacts under guest/target/ that contain literal PEM
    # bytes from the `pem` Rust crate (false positives) but never
    # land in committed files.
    if ! gitleaks detect --source "$REPO_ROOT" --no-banner --redact \
            --exit-code 1 >/dev/null 2>&1; then
        echo "❌ gitleaks found potential secrets in git history. Re-run:"
        echo "   gitleaks detect --source . --redact"
        exit 1
    fi
fi

# pip-audit / bandit are slower (~3-5s) and run in CI; skip locally
# unless explicitly requested via CROSSDESK_FULL_AUDIT=1.
if [ "${CROSSDESK_FULL_AUDIT:-0}" = "1" ]; then
    if command -v pip-audit >/dev/null 2>&1; then
        echo "🐍 pip-audit ..."
        pip-audit -r <(cd "$REPO_ROOT/host" && .venv/bin/pip freeze 2>/dev/null \
            | grep -v '^-e \|^crossdesk-host=') --quiet || {
            echo "❌ pip-audit found vulnerabilities."
            exit 1
        }
    fi
    if command -v bandit >/dev/null 2>&1; then
        echo "🐍 bandit (medium+) ..."
        bandit -r "$REPO_ROOT/host/src" -ll --quiet || exit 1
    fi
fi

echo "─────────────────────────────────────────────"
echo "✅ pre-push checks done."
exit 0
