# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml
*.swp

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Rust
target/
**/*.rs.bk

# Protobuf / buf
host/generated/
guest/crates/proto/src/generated/
buf.lock

# Build artefacts
*.tar
*.zip
dist/
build/

# GUI (Qt Linguist compiled translations)
gui/target/
*.qm

# Local mTLS material — never commit private keys.
# (Note: infra/certs/{ca,host,guest}.{key,crt} are already in git history from
#  the initial scaffolding; rotate them and run `git filter-repo` if going
#  public.)
infra/certs/pki/
*.key
*.csr
*.srl

# Claude Code per-project state — per-user / per-machine bits stay
# ignored (settings.json contains absolute paths like
# Read(//Users/<you>/.cargo/...)). Shared agent rules
# (.claude/rules/, architecture.md, ignorefiles.md) ARE tracked.
.claude/settings.json
.claude/settings.local.json
.claude/state/
.claude/cache/
.claude/projects/

# Large local recordings
*.mov

# Extracted video frames (local analysis artefacts)
frames/
