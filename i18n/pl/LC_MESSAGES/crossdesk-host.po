msgid ""
"note: full guest password re-apply for {username!r} requires a running "
"daemon and is wired through `display.session_starter` before the next RAIL "
"spawn."
msgstr ""
"uwaga: pełna zmiana hasła gościa dla {username!r} wymaga działającego "
"demona i nastąpi przez `display.session_starter` przed kolejnym "
"uruchomieniem RAIL."

